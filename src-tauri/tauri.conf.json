{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjectMender",
  "version": "0.1.0",
  "identifier": "com.projectmender.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "ProjectMender", "width": 960, "height": 680, "resizable": true }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'; img-src 'self' data:;" }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi"],
    "icon": ["icons/icon.png"],
    "macOS": { "minimumSystemVersion": "11.0" },
    "windows": { "wix": { "language": "en-US" } }
  }
}
